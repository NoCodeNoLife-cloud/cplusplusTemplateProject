# Doxyfile for cppforge
# Generated for project: cpp_project (cppforge)

#---------------------------------------------------------------------------
# Project related configuration options
#---------------------------------------------------------------------------
PROJECT_NAME           = "cppforge"
PROJECT_NUMBER         = 0.1.0
PROJECT_BRIEF          = "A C++ project template for rapid program development"
OUTPUT_DIRECTORY       = docs/api

#---------------------------------------------------------------------------
# Input related configuration options
#---------------------------------------------------------------------------
INPUT                  = common/include/cppforge \
                         starters/auth/include/cppforge \
                         starters/cache/include/cppforge \
                         starters/scheduler/include/cppforge \
                         starters/security/include/cppforge \
                         starters/tracing/include/cppforge
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp \
                         *.h
EXCLUDE_PATTERNS       = */generated/*

#---------------------------------------------------------------------------
# Build related configuration options
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = NO
EXTRACT_LOCAL_CLASSES  = YES

#---------------------------------------------------------------------------
# Configuration related to the source browser
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

#---------------------------------------------------------------------------
# Configuration options for the HTML output
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = AUTO_LIGHT

#---------------------------------------------------------------------------
# Configuration options for the LaTeX output
#---------------------------------------------------------------------------
GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# Configuration options for the Dot tool
#---------------------------------------------------------------------------
HAVE_DOT               = NO

#---------------------------------------------------------------------------
# General configuration
#---------------------------------------------------------------------------
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
